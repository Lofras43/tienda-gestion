<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<diagram name="Diagrama ER - Tienda Gestión" zoom="0.8" mxgraphModel="{&quot;root&quot;:{&quot;mxCell&quot;:[],&quot;UserObject&quot;:[]}}">
  <mxfile host="draw.io" modified="2026-04-13" agent="5.0" type="device" version="21.0.0">
    <diagram name="ER" id="er">
      <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1600" math="0" shadow="0">
        <root>
          <mxCell id="0" />
          <mxCell id="1" parent="0" />
          
          <!-- USUARIOS -->
          <mxCell id="tbl_usuarios" value="usuarios" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=1;marginBottom=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
            <mxGeometry x="40" y="40" width="200" height="150" as="geometry" />
          </mxCell>
          <mxCell id="tbl_usuarios_pk" value="PK - id (BIGINT, AUTO_INCREMENT)&#xa;- nombre (VARCHAR 100, NOT NULL)&#xa;- email (VARCHAR 150, NOT NULL, UNIQUE)&#xa;- password (VARCHAR 255, NOT NULL)&#xa;- rol (VARCHAR 20)&#xa;- fecha_registro (DATETIME)" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=11;fontColor=#333333;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="tbl_usuarios">
            <mxGeometry y="30" width="200" height="120" as="geometry" />
          </mxCell>
          
          <!-- PRODUCTOS -->
          <mxCell id="tbl_productos" value="productos" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=1;marginBottom=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
            <mxGeometry x="280" y="40" width="220" height="180" as="geometry" />
          </mxCell>
          <mxCell id="tbl_productos_pk" value="PK - id (BIGINT, AUTO_INCREMENT)&#xa;- nombre (VARCHAR 200, NOT NULL)&#xa;- descripcion (VARCHAR 500)&#xa;- precio_venta (DECIMAL 10,2)&#xa;- precio_compra (DECIMAL 10,2)&#xa;- stock (INT, NOT NULL)&#xa;- stock_minimo (INT)&#xa;- fecha_vencimiento (DATE)&#xa;- categoria (VARCHAR 50)&#xa;- esta_activo (BOOLEAN)" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=11;fontColor=#333333;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="tbl_productos">
            <mxGeometry y="30" width="220" height="150" as="geometry" />
          </mxCell>
          
          <!-- VENTAS -->
          <mxCell id="tbl_ventas" value="ventas" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=1;marginBottom=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
            <mxGeometry x="540" y="40" width="200" height="120" as="geometry" />
          </mxCell>
          <mxCell id="tbl_ventas_pk" value="PK - id (BIGINT, AUTO_INCREMENT)&#xa;- fecha_venta (DATETIME)&#xa;- total (DECIMAL 10,2)&#xa;FK - usuario_id (BIGINT) → usuarios.id" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=11;fontColor=#333333;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="tbl_ventas">
            <mxGeometry y="30" width="200" height="90" as="geometry" />
          </mxCell>
          
          <!-- DETALLE_VENTAS -->
          <mxCell id="tbl_detalle_ventas" value="detalle_ventas" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=1;marginBottom=0;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
            <mxGeometry x="540" y="200" width="220" height="140" as="geometry" />
          </mxCell>
          <mxCell id="tbl_detalle_ventas_pk" value="PK - id (BIGINT, AUTO_INCREMENT)&#xa;FK - venta_id (BIGINT) → ventas.id&#xa;FK - producto_id (BIGINT) → productos.id&#xa;- cantidad (INT, NOT NULL)&#xa;- precio_unitario (DECIMAL 10,2)&#xa;- subtotal (DECIMAL 10,2)" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=11;fontColor=#333333;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="tbl_detalle_ventas">
            <mxGeometry y="30" width="220" height="110" as="geometry" />
          </mxCell>
          
          <!-- COMPRAS -->
          <mxCell id="tbl_compras" value="compras" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=1;marginBottom=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
            <mxGeometry x="780" y="40" width="200" height="140" as="geometry" />
          </mxCell>
          <mxCell id="tbl_compras_pk" value="PK - id (BIGINT, AUTO_INCREMENT)&#xa;- fecha_compra (DATETIME)&#xa;- total (DECIMAL 10,2)&#xa;- proveedor (VARCHAR 200)&#xa;- numero_factura (VARCHAR 100)&#xa;- esta_activo (BOOLEAN)" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=11;fontColor=#333333;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="tbl_compras">
            <mxGeometry y="30" width="200" height="110" as="geometry" />
          </mxCell>
          
          <!-- RELACIONES -->
          <!-- Ventas -> Usuarios -->
          <mxCell id="er_rel1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="tbl_usuarios_pk" target="tbl_ventas_pk">
            <mxGeometry relative="1" as="geometry" />
          </mxCell>
          <mxCell id="er_rel1_label" value="N:1" style="resizable=0;align=center;verticalAlign=middle;spacingTop=-4;fontSize=12;fontColor=#333333;fontStyle=1" vertex="1" connectable="0" parent="er_rel1">
            <mxGeometry x="-10" y="15" relative="1" as="geometry" />
          </mxCell>
          
          <!-- DetalleVentas -> Ventas -->
          <mxCell id="er_rel2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="tbl_ventas_pk" target="tbl_detalle_ventas_pk">
            <mxGeometry relative="1" as="geometry" />
          </mxCell>
          <mxCell id="er_rel2_label" value="1:N" style="resizable=0;align=center;verticalAlign=middle;spacingTop=-4;fontSize=12;fontColor=#333333;fontStyle=1" vertex="1" connectable="0" parent="er_rel2">
            <mxGeometry x="-10" y="15" relative="1" as="geometry" />
          </mxCell>
          
          <!-- DetalleVentas -> Productos -->
          <mxCell id="er_rel3" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#666666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="tbl_detalle_ventas_pk" target="tbl_productos_pk">
            <mxGeometry relative="1" as="geometry" />
          </mxCell>
          <mxCell id="er_rel3_label" value="N:1" style="resizable=0;align=center;verticalAlign=middle;spacingTop=-4;fontSize=12;fontColor=#333333;fontStyle=1" vertex="1" connectable="0" parent="er_rel3">
            <mxGeometry x="-10" y="15" relative="1" as="geometry" />
          </mxCell>
          
          <!-- Llave foránea en compras (indicador) -->
          <mxCell id="fk_indicator" value="Nota: Las compras no tienen FK a productos en este diseño. El stock se actualiza directamente en la tabla productos." style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=10;fontColor=#666666;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
            <mxGeometry x="780" y="200" width="200" height="50" as="geometry" />
          </mxCell>
          
          <!-- Leyenda -->
          <mxCell id="leyenda_er" value="LEYENDA:&#xa;PK = Primary Key (Clave Primaria)&#xa;FK = Foreign Key (Clave Foránea)&#xa;N:1 = Muchos a Uno&#xa;1:N = Uno a Muchos" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];fontSize=10;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
            <mxGeometry x="40" y="280" width="180" height="70" as="geometry" />
          </mxCell>
          
        </root>
      </mxGraphModel>
    </diagram>
  </mxfile>
</diagram>